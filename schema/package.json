{
  "name": "schema",
  "type": "module",
  "private": true,
  "scripts": {
    "preview": "bunx @redocly/cli@1 preview-docs openapi/openapi.yaml --port 8081",
    "mock": "bunx @stoplight/prism-cli mock openapi/openapi.yaml --port 3001",
    "lint": "redocly lint",
    "build": "redocly build-docs openapi/openapi.yaml --output dist/index.html",
    "bundle": "redocly bundle openapi/openapi.yaml --output dist/openapi.yaml"
  },
  "devDependencies": {
    "@redocly/cli": "^2.31.6",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
